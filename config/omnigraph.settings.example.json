{
  "App": {
    "Environment": "Development",
    "PublicBaseUrl": "http://localhost:5000"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "RawTopic": "omnigraph.ingestion.raw",
    "ValidatedTopic": "omnigraph.ingestion.validated",
    "ExtractedTopic": "omnigraph.graph.extracted",
    "ProjectedTopic": "omnigraph.graph.projected",
    "DeadLetterTopic": "omnigraph.dlq",
    "ConsumerGroup": "omnigraph-processing"
  },
  "PostgreSql": {
    "ConnectionString": "Host=localhost;Port=5432;Database=omnigraph;Username=postgres;Password=postgres"
  },
  "Neo4j": {
    "Uri": "bolt://localhost:7687",
    "Username": "neo4j",
    "Password": "password",
    "Database": "neo4j"
  },
  "ObjectStorage": {
    "Provider": "LocalFileSystem",
    "BasePath": "C:\\OmniGraph\\raw-artifacts",
    "Bucket": "omnigraph-raw"
  },
  "Uploads": {
    "MaxFileSizeMb": 100,
    "AllowedExtensions": [
      ".xlsx",
      ".xls",
      ".pdf",
      ".png",
      ".jpg",
      ".jpeg",
      ".log",
      ".txt",
      ".cs",
      ".js",
      ".ts",
      ".py"
    ]
  },
  "AI": {
    "DefaultProvider": "Ollama",
    "TextProvider": "Ollama",
    "VisionProvider": "OpenAI",
    "EmbeddingProvider": "OpenAI",
    "EnableVisionModels": true,
    "EnableOptionalEmbeddings": true,
    "ModelName": "gpt-4.1-mini",
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "ChatModel": "llama3.1:8b",
      "VisionModel": "llava:7b",
      "EmbeddingModel": "nomic-embed-text"
    },
    "OpenAI": {
      "Enabled": true,
      "BaseUrl": "https://api.openai.com/v1",
      "ApiKey": "paste-openai-key-here",
      "ChatModel": "gpt-4.1-mini",
      "VisionModel": "gpt-4.1-mini",
      "EmbeddingModel": "text-embedding-3-small"
    },
    "Anthropic": {
      "Enabled": false,
      "BaseUrl": "https://api.anthropic.com",
      "ApiKey": "paste-anthropic-key-here",
      "ChatModel": "claude-3-5-sonnet-latest",
      "VisionModel": "claude-3-5-sonnet-latest"
    },
    "AzureOpenAI": {
      "Enabled": false,
      "Endpoint": "https://your-resource.openai.azure.com/",
      "ApiKey": "paste-azure-openai-key-here",
      "ChatDeployment": "gpt-4.1-mini",
      "VisionDeployment": "gpt-4.1-mini",
      "EmbeddingDeployment": "text-embedding-3-small"
    }
  },
  "Parsers": {
    "Excel": {
      "HeaderRowDetection": true,
      "InferPrimaryKeys": true
    },
    "Pdf": {
      "UseNativeTextFirst": true,
      "FallbackToOcr": true
    },
    "Images": {
      "UseOcr": true,
      "UseCaptioning": true
    },
    "Logs": {
      "DefaultTimezone": "UTC",
      "EnableCorrelationLinking": true
    },
    "Code": {
      "ExtractAst": true,
      "BuildCallGraph": true
    }
  }
}
